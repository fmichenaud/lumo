    "Crée un affichage permanent (texte, couleur, icône) ajouté à la rotation de l'écran.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create a permanent display (text, color, icon) added to the screen rotation."
          }
        }
      }
    },
    "Sauvegarde tes compositions et renvoie-les en 1 clic. Elles survivent au redémarrage du device.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Save your compositions and resend them in one click. They survive a device reboot."
          }
        }
      }
    },
    "Affiche la météo de ta ville sur l'écran, avec mise à jour automatique possible.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Show your city's weather on the screen, with optional auto-refresh."
          }
        }
      }
    },
    "Signaux ponctuels : une notification qui s'affiche puis disparaît, et les 3 LED témoins.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One-off signals: a notification that appears then disappears, and the 3 indicator LEDs."
          }
        }
      }
    },
    "Affiche des graphiques, le cours d'une crypto ou les stats de ton Mac.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Show charts, a crypto price, or your Mac's stats."
          }
        }
      }
    },
    "Connecte n'importe quelle API (la tienne ou une externe) et affiche-la en direct.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Connect any API (yours or third-party) and display it live."
          }
        }
      }
    },
    "Dessine pixel par pixel et envoie ton image sur la matrice.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Draw pixel by pixel and send your image to the matrix."
